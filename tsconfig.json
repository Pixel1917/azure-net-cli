{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"rootDir": ".",
		"outDir": "dist",
		"allowJs": true,
		"checkJs": false,
		"declaration": true,
		"sourceMap": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["bin/**/*.ts", "src/**/*"],
	"exclude": ["dist", "node_modules"]
}
